{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "module": "CommonJS",
        "moduleResolution": "node",
        "noEmit": false,
        "target": "ES2019",
        "esModuleInterop": true
    },
    "include": ["server/**/*", "api/**/*"],
    "ts-node": {
        "esm": true
    }
}